{
  "name": "@found-in-space/journey-video",
  "private": true,
  "version": "0.0.0-alpha.0",
  "description": "Standalone journey video editor and deterministic export tooling",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.js",
  "types": "./src/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "default": "./src/index.js"
    },
    "./editor": {
      "types": "./src/editor.d.ts",
      "default": "./src/editor.js"
    },
    "./export": {
      "types": "./src/export.d.ts",
      "default": "./src/export.js"
    },
    "./export/node": {
      "types": "./src/export-node.d.ts",
      "default": "./src/export-node.js"
    }
  },
  "bin": {
    "journey-video-render": "./bin/journey-video-render.js"
  },
  "files": [
    "bin",
    "src",
    "examples",
    "index.html",
    "README.md",
    "TODO.md"
  ],
  "sideEffects": false,
  "scripts": {
    "dev": "vite",
    "build": "npm run typecheck && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test",
    "test:integration:export": "JOURNEY_VIDEO_EXPORT_INTEGRATION=1 node --test src/__integration__/journey-video-export.integration.mjs",
    "video:install-browsers": "playwright install chromium firefox webkit",
    "video:journey:test": "node ./bin/journey-video-render.js --mode=preview --layout=landscape-1080p --frames=2 --fps=1 --journey=examples/radio-bubble/radio-bubble-journey.json --output-dir=video-output/journey-video-smoke",
    "video:journey:preview": "node ./bin/journey-video-render.js --mode=preview --journey=examples/radio-bubble/radio-bubble-journey.json"
  },
  "dependencies": {
    "@found-in-space/anchored-image": "file:../skykit/packages/anchored-image",
    "@found-in-space/hr-diagram": "file:../skykit/packages/hr-diagram",
    "@found-in-space/journey": "file:../skykit/packages/journey",
    "@found-in-space/skykit": "file:../skykit/packages/skykit",
    "@found-in-space/spatial": "file:../skykit/packages/spatial",
    "@found-in-space/star-octree-provider": "file:../skykit/packages/star-octree-provider",
    "@found-in-space/star-trees": "file:../skykit/packages/star-trees",
    "@found-in-space/three-star-field": "file:../skykit/packages/three-star-field",
    "lucide": "^1.16.0",
    "three": "^0.170.0"
  },
  "devDependencies": {
    "playwright": "1.60.0",
    "typescript": "^5.9.3",
    "vite": "^6.0.0"
  },
  "peerDependencies": {
    "playwright": "1.60.0",
    "three": "^0.170.0"
  },
  "peerDependenciesMeta": {
    "playwright": {
      "optional": true
    }
  }
}
